# .env.example — 환경변수 템플릿
# 실제 사용 시 .env 파일로 복사 후 값 입력
# 절대 .env를 git에 커밋하지 말 것 (.gitignore 참고)

# ── 서버 설정 ─────────────────────────────────────────────────────────
ENV=development             # development | production
SERVER_PORT=8080
LOG_LEVEL=debug             # debug | info | warn | error

# ── 데이터베이스 ─────────────────────────────────────────────────────
DB_PATH=./data/chart_analyzer.db

# ── Binance (코인 데이터) ──────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
# WebSocket: wss://stream.binance.com:9443 (공개 — API Key 불필요)

# ── Tiingo (주식 데이터 — 권장) ──────────────────────────────────────
# 무료 계정: https://www.tiingo.com → Account → API → Create Token
# 설정 시 Yahoo Finance 대신 Tiingo를 주 데이터 소스로 자동 사용
TIINGO_API_KEY=
# 폴 간격 (초). 무료 티어: 50 req/hr → 900(15분) 권장. 기본값 900.
# 1D/1W 데이터는 내부적으로 각각 6시간/24시간 캐시 → 실제 요청 수 훨씬 적음
TIINGO_POLL_INTERVAL=900

# ── Yahoo Finance (주식 데이터 — TIINGO_API_KEY 미설정 시 자동 fallback) ─
# 공개 비공식 API — Key 불필요 / 불안정 가능성 있음
YAHOO_POLL_INTERVAL=60

# ── Telegram Bot ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord Webhook ───────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── 알림 쿨다운 ───────────────────────────────────────────────────────
ALERT_COOLDOWN_HOURS=4

# ── LLM 해석 레이어 ─────────────────────────────────────────────
LLM_PROVIDER=    # anthropic | openai | groq | gemini
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MIN_SCORE=7.0