# .env.example — 환경변수 템플릿
# 실제 사용 시 .env 파일로 복사 후 값 입력
# 절대 .env를 git에 커밋하지 말 것 (.gitignore 참고)

# ── 서버 설정 ─────────────────────────────────────────────────────────
ENV=development             # development | production
SERVER_PORT=8080
LOG_LEVEL=debug             # debug | info | warn | error

# ── 데이터베이스 ─────────────────────────────────────────────────────
DB_PATH=./data/chart_analyzer.db

# ── Binance (코인 데이터) ──────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
# WebSocket: wss://stream.binance.com:9443 (공개 — API Key 불필요)

# ── Yahoo Finance (주식 데이터) ───────────────────────────────────────
# 공개 API — 별도 Key 불필요
# 폴링 간격 (초)
YAHOO_POLL_INTERVAL=60

# ── Telegram Bot ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord Webhook ───────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── 알림 쿨다운 ───────────────────────────────────────────────────────
ALERT_COOLDOWN_HOURS=4

# ── Claude AI 해석 레이어 ─────────────────────────────────────────────
# ANTHROPIC_API_KEY 미설정 시 AI 해석 비활성화 (룰 엔진 신호만 발송)
ANTHROPIC_API_KEY=
AI_MIN_SCORE=12.0           # 이 점수 이상일 때만 AI 해석 호출 (비용 절감)
