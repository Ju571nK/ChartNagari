# .env.example — Environment variable template
# Copy to .env and fill in your values.
# Never commit .env to git (it is in .gitignore).

# ── Server ────────────────────────────────────────────────────────────
ENV=development             # development | production
SERVER_PORT=8080
LOG_LEVEL=debug             # debug | info | warn | error

# ── Database ─────────────────────────────────────────────────────────
DB_PATH=./data/chart_analyzer.db

# ── Binance (crypto data) ─────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
# Public WebSocket: wss://stream.binance.com:9443 — no API key required

# ── Tiingo (stock data — recommended) ────────────────────────────────
# Free account: https://www.tiingo.com → Account → API → Create Token
# When set, Tiingo is used instead of Yahoo Finance as the primary data source
TIINGO_API_KEY=
# Poll interval (seconds). Free tier: 50 req/hr → 900 (15 min) recommended.
# 1D/1W data is cached internally (6h/24h) so actual request count is much lower.
TIINGO_POLL_INTERVAL=900

# ── Yahoo Finance (stock data — fallback when TIINGO_API_KEY is unset) ─
# Public unofficial API — no key required / may be unstable
YAHOO_POLL_INTERVAL=60

# ── Telegram Bot ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord Webhook ───────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Alert cooldown ────────────────────────────────────────────────────
ALERT_COOLDOWN_HOURS=4

# ── LLM interpretation layer ─────────────────────────────────────────
LLM_PROVIDER=               # anthropic | openai | groq | gemini
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
AI_MIN_SCORE=12.0
LLM_LANGUAGE=en             # en | ko | ja

# ── AlphaVantage (optional — 20-year daily SPY data) ─────────────────
ALPHAVANTAGE_API_KEY=
